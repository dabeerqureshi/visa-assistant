generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  country   String    @default("Pakistan")
  createdAt DateTime  @default(now())
  cases     VisaCase[]
}

model VisaCase {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  country        String        // UK | Netherlands | USA | Canada | Australia | etc.
  visaType       String        @default("visit") // visit | student | work
  status         String        @default("draft") // draft | in_progress | ready_for_review | needs_changes | ready_to_submit | completed

  // === COMMON PERSONAL DETAILS (all visa types) ===
  age            Int?
  maritalStatus  String?       // single | married | divorced | widowed
  city           String?
  ownHouse       Boolean?      @default(false)
  hasRentalProperties Boolean?  @default(false)
  hasBusinesses  Boolean?      @default(false)

  // === COMMON FINANCIAL ===
  jobType        String?       // salaried | business | student | unemployed | retired
  income         Float?
  bankBalance    Float?
  bankStatementStatus String?  // 6_months | 3_months | not_available
  monthlyExpenses Float?

  // === COMMON TRAVEL & REJECTION ===
  travelHistory  String?       // none | limited | moderate | extensive
  purpose        String?       // tourism | business | family_visit | medical | education
  previousVisaRejection   Boolean?  @default(false)
  previousVisaRejectionReason String? // reason or "dont_know"
  previousVisaRejectionCountry String?

  // === VISIT VISA SPECIFIC ===
  sponsorName    String?
  sponsorRelation String?
  durationDays   Int?
  travelInsurance Boolean?     @default(false)
  accommodationBooked Boolean? @default(false)
  returnTicketBooked Boolean?  @default(false)

  // === STUDENT VISA SPECIFIC ===
  universityName        String?
  universityCountry     String?
  courseName            String?
  courseLevel           String?   // bachelors | masters | phd | diploma | foundation
  previousEducation     String?   // JSON array of {degree, institution, year, marks, grade}
  ieltsScore            Float?
  toeflScore            Float?
  hasAcceptanceLetter   Boolean?  @default(false)
  tuitionFee            Float?
  scholarshipAmount     Float?
  financialSponsor      String?
  gapYears              Int?
  hasStudentLoan        Boolean?  @default(false)
  accommodationPlan     String?   // university_halls | private_rental | with_family

  // === WORK VISA SPECIFIC ===
  jobOfferCompany       String?
  jobTitle              String?
  contractDurationMonths Int?
  yearsOfExperience     Int?
  highestQualification  String?   // high_school | bachelors | masters | phd
  professionalCertifications String? // comma-separated or JSON
  salaryOffered         Float?
  hasWorkPermitSponsor  Boolean?  @default(false)
  currentEmployer       String?
  noticePeriodDays      Int?

  // === TIMESTAMPS & RELATIONS ===
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  documents      Document[]
  checklist      DocumentChecklist[]
  adminReview    AdminReview?
  reportUrl      String?
}

model Document {
  id        String   @id @default(cuid())
  caseId    String
  case      VisaCase @relation(fields: [caseId], references: [id])
  type      String   // passport | bank_statement | salary_slip | etc.
  category  String   // identity | financial | employment | travel | sponsorship | academic | medical | other
  fileName  String
  fileUrl   String
  status    String   @default("uploaded") // uploaded | missing | weak
  notes     String?
  createdAt DateTime @default(now())
}

model DocumentChecklist {
  id           String   @id @default(cuid())
  caseId       String
  case         VisaCase @relation(fields: [caseId], references: [id])
  documentKey  String   // passport | bank_statement | etc.
  documentName String
  category     String   // identity | financial | employment | travel | sponsorship | academic | medical | other
  hasDocument  Boolean  @default(false)
  notes        String?  // user can add notes like "I have it but need to find", "dont_know", etc.
  adminStatus  String   @default("pending") // pending | verified | needs_clarification | missing
  adminNotes   String?
  updatedAt    DateTime @updatedAt
}

model Requirement {
  id           String @id @default(cuid())
  country      String // UK | Netherlands | USA | Canada | Australia | etc.
  visaType     String @default("visit")
  userType     String // salaried | business | student | unemployed | retired | all
  documentName String
  documentKey  String // machine-readable key
  category     String // identity | financial | employment | travel | sponsorship | academic | medical | other
  required     Boolean @default(true)
  description  String?
}

model AdminReview {
  id            String   @id @default(cuid())
  caseId        String   @unique
  case          VisaCase @relation(fields: [caseId], references: [id])
  comment       String
  suggestions   String?  // Admin's improvement suggestions
  severity      String   @default("info") // info | warning | critical
  status        String   @default("pending") // pending | reviewed | approved | flagged | needs_changes
  readyToSubmit Boolean  @default(false) // true when application is perfect and ready to submit
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}